<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane styleClass="root-pane" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.cincuentazo.Controllers.GameController">

    <!-- ================= NORTE: barra de turno + Máquina 2 ================= -->
    <top>
        <VBox alignment="CENTER" spacing="14" BorderPane.alignment="CENTER">
            <VBox alignment="CENTER" spacing="4" styleClass="top-bar">
                <padding>
                    <Insets bottom="12" top="12" />
                </padding>
                <Label fx:id="lblPlayerTurn" styleClass="turn-label" text="Cargando..." />
                <Label fx:id="lblTimer" styleClass="timer-label" text="Tiempo: 0s" />
            </VBox>

            <VBox fx:id="machine2Box" alignment="CENTER" spacing="6" styleClass="player-zone">
                <padding>
                    <Insets bottom="10" top="4" />
                </padding>
            </VBox>
        </VBox>
    </top>

    <!-- ================= OESTE: Máquina 1 ================= -->
    <left>
        <VBox fx:id="machine1Box" alignment="CENTER" spacing="6" styleClass="player-zone" BorderPane.alignment="CENTER">
            <padding>
                <Insets left="26" right="18" />
            </padding>
        </VBox>
    </left>

    <!-- ================= ESTE: Máquina 3 ================= -->
    <right>
        <VBox fx:id="machine3Box" alignment="CENTER" spacing="6" styleClass="player-zone" BorderPane.alignment="CENTER">
            <padding>
                <Insets left="18" right="26" />
            </padding>
        </VBox>
    </right>

    <!-- ================= CENTRO: mazo · escudo de suma · descartes ================= -->
    <center>
        <VBox alignment="CENTER" spacing="18" BorderPane.alignment="CENTER">
            <HBox alignment="CENTER" spacing="100" styleClass="table-area">

                <!-- Mazo de robo (izquierda) -->
                <VBox alignment="CENTER" spacing="8">
                    <StackPane fx:id="drawPileContainer" onMouseClicked="#handleDrawPileClick" styleClass="draw-pile">
                        <ImageView fx:id="imgDrawPile" fitHeight="132" fitWidth="90" preserveRatio="true">
                            <image>
                                <Image url="@imagenes/back.jpg" />
                            </image>
                        </ImageView>
                    </StackPane>
                    <Label styleClass="pile-caption" text="Mazo" />
                </VBox>

                <!-- Escudo de suma (centro): la suma va DEBAJO del escudo, no encima -->
                <VBox alignment="CENTER" spacing="4">
                    <ImageView fitHeight="190" fitWidth="168" preserveRatio="true">
                        <image>
                            <Image url="@imagenes/escudo.png" />
                        </image>
                    </ImageView>
                    <Label fx:id="lblTableSum" prefHeight="32.0" prefWidth="176.0" styleClass="sum-label" text="Suma: 0" />
                </VBox>

                <!-- Pila de descartes (derecha) -->
                <VBox alignment="CENTER" spacing="8">
                    <ImageView fx:id="imgActiveCard" fitHeight="132" fitWidth="90" preserveRatio="true" />
                    <Label styleClass="pile-caption" text="Descartes" />
                </VBox>
            </HBox>

            <Label fx:id="lblMessage" styleClass="message-label" />
        </VBox>
    </center>

    <!-- ================= SUR: mano del jugador humano ================= -->
    <bottom>
        <VBox fx:id="humanBox" alignment="CENTER" spacing="10" styleClass="player-zone" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="34" top="10" />
            </padding>
            <Label styleClass="hand-title" text="Tu mano" />
            <HBox fx:id="playerHandContainer" alignment="CENTER" spacing="14" />
        </VBox>
    </bottom>
</BorderPane>
