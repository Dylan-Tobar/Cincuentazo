<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.cincuentazo.Controllers.GameController"
            stylesheets="@style.css" styleClass="root-pane">

    <top>
        <VBox alignment="CENTER" spacing="4" styleClass="top-bar" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="12" top="12"/>
            </padding>
            <Label fx:id="lblPlayerTurn" styleClass="turn-label" text="Cargando..."/>
            <Label fx:id="lblTimer" styleClass="timer-label" text="Tiempo: 0s"/>
        </VBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="22" BorderPane.alignment="CENTER">
            <HBox fx:id="opponentsContainer" alignment="CENTER" spacing="30"/>

            <VBox alignment="CENTER" spacing="8" styleClass="table-area">
                <ImageView fx:id="imgActiveCard" fitHeight="140" fitWidth="95" preserveRatio="true"/>

                <!-- Escudo + suma: ambos definidos aquí mismo, así el Label
                     siempre queda inyectado por FXML y nunca llega null al controlador -->
                <StackPane alignment="CENTER">
                    <ImageView fitHeight="170" fitWidth="150" preserveRatio="true">
                        <image>
                            <Image url="@imagenes/escudo.png"/>
                        </image>
                    </ImageView>
                    <Label fx:id="lblTableSum" styleClass="sum-label" text="Suma: 0"/>
                </StackPane>
            </VBox>

            <Label fx:id="lblMessage" styleClass="message-label"/>
        </VBox>
    </center>

    <bottom>
        <VBox alignment="CENTER" spacing="8" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="24" top="16"/>
            </padding>
            <Label styleClass="hand-title" text="Tu mano"/>
            <HBox fx:id="playerHandContainer" alignment="CENTER" spacing="14"/>
        </VBox>
    </bottom>
</BorderPane>
